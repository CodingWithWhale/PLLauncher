<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PLLauncher.Views.DashboardPage"
             Background="{DynamicResource BackgroundBrush}">

    <ScrollViewer Padding="32,28">
        <StackPanel Spacing="24">
            <!-- Greeting -->
            <StackPanel Spacing="4">
                <TextBlock x:Name="GreetingText" Text="Good morning" FontSize="28" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock x:Name="SubtitleText" Text="Here's your productivity overview" FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
            </StackPanel>

            <!-- Stats Row -->
            <UniformGrid Columns="4">
                <Border Margin="0,0,8,0" Classes="CardBorder" Background="{DynamicResource CardBackgroundBrush}"
                        CornerRadius="8" Padding="16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock Text="&#xE92E;" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock x:Name="HotkeyCount" Text="0" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock x:Name="HotkeysLabel" Text="Active Hotkeys" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                </Border>
                <Border Margin="4,0" Classes="CardBorder" Background="{DynamicResource CardBackgroundBrush}"
                        CornerRadius="8" Padding="16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock Text="&#xE916;" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="{DynamicResource WarningBrush}" />
                        <TextBlock x:Name="TaskCount" Text="0" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock x:Name="TasksLabel" Text="Active Tasks" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                </Border>
                <Border Margin="4,0" Classes="CardBorder" Background="{DynamicResource CardBackgroundBrush}"
                        CornerRadius="8" Padding="16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock Text="&#xE917;" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="{DynamicResource ErrorBrush}" />
                        <TextBlock x:Name="LimitCount" Text="0" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock x:Name="LimitsLabel" Text="Time Limits" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                </Border>
                <Border Margin="8,0,0,0" Classes="CardBorder" Background="{DynamicResource CardBackgroundBrush}"
                        CornerRadius="8" Padding="16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="{DynamicResource SuccessBrush}" />
                        <TextBlock x:Name="ScheduleCount" Text="0" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock x:Name="SchedulesLabel" Text="Schedules" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Quick Actions -->
            <StackPanel Spacing="12">
                <TextBlock x:Name="QuickActionsLabel" Text="Quick Actions" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                <UniformGrid Columns="3">
                    <Button x:Name="AntiSleepBtn" Margin="0,0,8,0" Click="ToggleAntiSleep_Click"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            CornerRadius="8" Background="{DynamicResource Surface2Brush}"
                            Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Padding="16">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE917;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" />
                            <TextBlock x:Name="AntiSleepText" Text="Anti-Sleep" FontSize="12" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Margin="4,0" Click="QuickShutdown_Click" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center" CornerRadius="8"
                            Background="{DynamicResource Surface2Brush}" Foreground="{DynamicResource TextPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="16">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{DynamicResource ErrorBrush}" HorizontalAlignment="Center" />
                            <TextBlock x:Name="ShutdownText" Text="Shutdown 1h" FontSize="12" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Margin="8,0,0,0" Click="QuickLock_Click" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center" CornerRadius="8"
                            Background="{DynamicResource Surface2Brush}" Foreground="{DynamicResource TextPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="16">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{DynamicResource WarningBrush}" HorizontalAlignment="Center" />
                            <TextBlock x:Name="LockText" Text="Lock PC" FontSize="12" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </UniformGrid>
            </StackPanel>

            <!-- System Status -->
            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Padding="16"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" />
                    <StackPanel Spacing="2">
                        <TextBlock x:Name="StatusLabel" Text="System Status" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock x:Name="SystemStatusText" Text="All systems operational" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
