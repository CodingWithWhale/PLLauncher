<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PLLauncher.Views.ReminderPopup"
        Title="Reminder"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="Manual"
        Topmost="True"
        ShowInTaskbar="True"
        CanResize="False"
        Background="{DynamicResource CardBackgroundBrush}"
        ExtendClientAreaToDecorationsHint="True"
        TransparencyLevelHint="AcrylicBlur">

    <Border x:Name="RootBorder" CornerRadius="8" Padding="20" Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource WarningBrush}" BorderThickness="2">
        <StackPanel Spacing="16">
            <!-- Header -->
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Border x:Name="UrgencyIcon" Width="36" Height="36" CornerRadius="8" Background="#33FF9800">
                    <TextBlock x:Name="UrgencyIconText" Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                               Foreground="{DynamicResource WarningBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Spacing="2" VerticalAlignment="Center">
                    <TextBlock x:Name="UrgencyLabel" Text="Meh" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="Reminder" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- Reminder Title -->
            <TextBlock x:Name="ReminderTitle" Text="Title" FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />

            <!-- Reminder Message -->
            <Border x:Name="MessageBorder" Background="{DynamicResource SurfaceBrush}" CornerRadius="6" Padding="12"
                    IsVisible="False">
                <TextBlock x:Name="ReminderMessage" Text="" FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
            </Border>

            <!-- Dismiss Button -->
            <Button Click="Dismiss_Click" CornerRadius="6" Padding="12,10"
                    Background="{DynamicResource AccentSecondaryBrush}" Foreground="White"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               VerticalAlignment="Center" />
                    <TextBlock Text="Got it" FontSize="14" FontWeight="Medium" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Border>
</Window>
