<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PLLauncher.App"
             RequestedThemeVariant="Dark">
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <!-- Color Palette - Dark Theme (default) -->
        <!-- NOTE: Brushes are NOT defined here. They are created programmatically
             in App.Initialize() to avoid Avalonia freezing them into ImmutableSolidColorBrush.
             SetTheme() replaces them with new mutable brushes. -->
        <Color x:Key="AccentColor">#60CDFF</Color>
        <Color x:Key="AccentColorSecondary">#0078D4</Color>
        <Color x:Key="BackgroundColor">#0A0A0A</Color>
        <Color x:Key="SurfaceColor">#1C1C1C</Color>
        <Color x:Key="SurfaceColor2">#2D2D2D</Color>
        <Color x:Key="CardBackgroundColor">#1E1E1E</Color>
        <Color x:Key="SidebarBackgroundColor">#0F0F0F</Color>
        <Color x:Key="TextPrimaryColor">#FFFFFF</Color>
        <Color x:Key="TextSecondaryColor">#9E9E9E</Color>
        <Color x:Key="TextTertiaryColor">#6E6E6E</Color>
        <Color x:Key="BorderColor">#3D3D3D</Color>
        <Color x:Key="SuccessColor">#4CAF50</Color>
        <Color x:Key="WarningColor">#FF9800</Color>
        <Color x:Key="ErrorColor">#F44336</Color>
        <Color x:Key="InfoColor">#2196F3</Color>

        <!-- CornerRadius -->
        <CornerRadius x:Key="CardCornerRadius">8</CornerRadius>
        <CornerRadius x:Key="ButtonCornerRadius">6</CornerRadius>
        <CornerRadius x:Key="InputCornerRadius">4</CornerRadius>

        <!-- Spacing -->
        <x:Double x:Key="PagePadding">32</x:Double>
        <x:Double x:Key="CardPadding">16</x:Double>
        <x:Double x:Key="ItemSpacing">8</x:Double>

        <!-- Font -->
        <FontFamily x:Key="AppFontFamily">Inter</FontFamily>

        <!-- Styles -->
        <Style x:Key="CardStyle" Selector="Border.CardBorder">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Application.Resources>
</Application>
